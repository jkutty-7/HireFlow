# ─── LLM Providers ───────────────────────────────────────────
NVIDIA_API_KEY=nvapi-your-nvidia-nim-api-key-here
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-api-key-here

# ─── Candidate Data APIs ─────────────────────────────────────
APOLLO_API_KEY=your-apollo-io-master-api-key
GITHUB_TOKEN=ghp_your-github-personal-access-token
HUNTER_API_KEY=your-hunter-io-api-key

# ─── Circle Infrastructure ───────────────────────────────────
CIRCLE_API_KEY=TEST_API_KEY:your-circle-api-key
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
USDC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000001
CIRCLE_KIT_KEY=KIT_KEY:your-circle-kit-key

# ─── Smart Contracts (populated after contracts/deploy.py runs) ───
AGENT_REGISTRY_ADDRESS=
PAYMENT_ESCROW_ADDRESS=
PAYMENT_ROUTER_ADDRESS=

# ─── Circle Wallet IDs (populated after payments/wallet_manager.py runs) ───
ORCHESTRATOR_WALLET_ID=
APOLLO_AGENT_WALLET_ID=
GITHUB_AGENT_WALLET_ID=
HUNTER_AGENT_WALLET_ID=
SCORING_AGENT_WALLET_ID=
JD_PARSER_WALLET_ID=

# ─── Wallet Private Keys (for EIP-3009 signing) ───────────────
# Generate with: python -c "from eth_account import Account; [print(Account.create().key.hex()) for _ in range(6)]"
ORCHESTRATOR_PRIVATE_KEY=0x
APOLLO_PRIVATE_KEY=0x
GITHUB_PRIVATE_KEY=0x
HUNTER_PRIVATE_KEY=0x
SCORING_PRIVATE_KEY=0x
JD_PARSER_PRIVATE_KEY=0x

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/hireflow

# ─── App ──────────────────────────────────────────────────────
ENVIRONMENT=testnet
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-32-char-string
